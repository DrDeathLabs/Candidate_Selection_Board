{
  "name": "selection-board-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:batch-small": "node ./tests/e2e/run-batch-regression.mjs --runs 3 --min-resumes 10 --max-resumes 15",
    "test:e2e:batch-25": "node ./tests/e2e/run-batch-regression.mjs --runs 25 --min-resumes 10 --max-resumes 100",
    "test:e2e:batch-50": "node ./tests/e2e/run-batch-regression.mjs --runs 50 --min-resumes 10 --max-resumes 100"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.8",
    "axios": "^1.7.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^5.6.3",
    "vite": "^7.3.5"
  }
}
