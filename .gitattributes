# Normalize all text files to LF in the repo; check out as native on each OS
* text=auto eol=lf

# Force LF for shell scripts regardless of OS
*.sh text eol=lf
*.bash text eol=lf

# Force LF for Python, TypeScript, JSON, YAML
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.env text eol=lf
*.example text eol=lf

# Binaries — no diff, no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
