COMPOSE_PROJECT_NAME=resume_review_sb
IMAGE_TAG=latest
HOST_BIND_ADDRESS=127.0.0.1
APP_HTTP_PORT=8610
FRONTEND_PORT=8611
API_PORT=8612
MINIO_API_PORT=8613
MINIO_CONSOLE_PORT=8614

POSTGRES_DB=selection_board
POSTGRES_USER=selection_board
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=database
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET=selection-board
S3_ENDPOINT_URL=http://object-storage:9000
S3_REGION=us-east-1
PARSER_SERVICE_URL=http://parser:8010
VIRUS_SCANNER_HOST=virus-scanner
VIRUS_SCANNER_PORT=3310

OPENSEARCH_URL=http://search:9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=ChangeMeSearch!8614

OIDC_ISSUER_URL=https://login.example.gov
OIDC_AUDIENCE=selection-board
OIDC_JWKS_URL=https://login.example.gov/.well-known/jwks.json

AI_GATEWAY_URL=http://ai-gateway:8020
AI_DEFAULT_PROVIDER=ollama
AI_ALLOWED_MODELS=gpt-oss:120b-cloud,gpt-4.1,claude-sonnet,gemini-2.5-pro
AI_GATEWAY_API_KEY=change-me
OUTSIDE_ENRICHMENT_ALLOWED=false

CORS_ORIGINS=http://127.0.0.1:8610,http://localhost:8610,http://127.0.0.1:8611,http://localhost:8611
LOG_LEVEL=INFO
ENVIRONMENT=local

# Security — set these before production deployment
DEV_AUTH_BYPASS=true                  # Set to false in production (requires real auth headers)
REDIS_PASSWORD=                        # Set a strong password in production
POSTGRES_SSL_MODE=prefer              # Set to require in production
OPENSEARCH_SECURITY_DISABLED=true     # Set to false in production

# ── Auth & Session (FISMA AC-11, AC-12, AC-7, AC-10) ──────────────────────
SESSION_IDLE_TIMEOUT_MINUTES=15        # FISMA AC-11 max: 15
SESSION_ABSOLUTE_TIMEOUT_HOURS=8       # FISMA AC-12 max: 8
SESSION_COOKIE_SECURE=false            # Set true in production (requires HTTPS)
SESSION_COOKIE_NAME=sb_session
MAX_CONCURRENT_SESSIONS=3              # FISMA AC-10
MAX_FAILED_LOGIN_ATTEMPTS=5            # FISMA AC-7 max: 5
ACCOUNT_LOCKOUT_MINUTES=30

# ── Password Policy (FISMA IA-5) ──────────────────────────────────────────
PASSWORD_MIN_LENGTH=14                 # FISMA IA-5 min: 14
PASSWORD_HISTORY_COUNT=5
PASSWORD_MAX_AGE_DAYS=90

# ── TOTP / MFA (FISMA IA-2) ───────────────────────────────────────────────
TOTP_ISSUER_NAME=Candidate Selection Board
TOTP_ENCRYPTION_KEY=replace-with-32-byte-fernet-key  # REQUIRED in production — see SECURITY.md

# ── OIDC Group Mapping ────────────────────────────────────────────────────
OIDC_GROUP_PREFIX=selection-board-
OIDC_REDIRECT_BASE_URL=http://127.0.0.1:8610  # Set to public HTTPS base URL in production

# ── Internal Service Identity ─────────────────────────────────────────────
SERVICE_NAME=api
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
